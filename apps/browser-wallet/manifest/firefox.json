{
  "manifest_version": 3,
  "name": "Chipcoin Wallet",
  "version": "0.1.0",
  "description": "Chipcoin devnet browser wallet",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Chipcoin Wallet"
  },
  "background": {
    "scripts": ["assets/background.js"],
    "type": "module"
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "chipcoin-wallet@chipcoin.local"
    }
  }
}
