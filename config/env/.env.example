CHIPCOIN_NETWORK=devnet
COMPOSE_PROJECT_NAME=chipcoin
CHIPCOIN_RUNTIME_DIR=/path/to/Chipcoin-runtime

# Public devnet defaults
# These are fallback defaults only. Replace them freely for your own environment.
DEFAULT_NODE_ENDPOINT=http://tiltmediaconsulting.com:8081
DEFAULT_BOOTSTRAP_PEER=tiltmediaconsulting.com:18444
DEFAULT_EXPLORER_URL=http://tiltmediaconsulting.com:4173

# Node
# Phase 1 node runtime does not consume a wallet file yet.
# Public devnet P2P uses TCP 18444. Keep this port consistent with your router/firewall
# rules if you want the node to be reachable by other peers.
NODE_DATA_PATH=/path/to/Chipcoin-runtime/data/node-devnet.sqlite3
NODE_LOG_LEVEL=INFO
NODE_P2P_BIND_PORT=18444
NODE_HTTP_BIND_PORT=8081
CHIPCOIN_HTTP_ALLOWED_ORIGINS=

# Miner
MINER_DATA_PATH=/path/to/Chipcoin-runtime/data/miner-devnet.sqlite3
MINER_LOG_LEVEL=INFO
MINER_WALLET_FILE=/path/to/Chipcoin-runtime/wallets/chipcoin-wallet.json
MINER_P2P_BIND_PORT=18445
MINING_MIN_INTERVAL_SECONDS=1.0

# Browser wallet
BROWSER_WALLET_DEFAULT_NODE_ENDPOINT=http://tiltmediaconsulting.com:8081

# Discovery
DIRECT_PEER=tiltmediaconsulting.com:18444
BOOTSTRAP_URL=
